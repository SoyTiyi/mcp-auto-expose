  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "fastify": "^5.0.0",
    "tsx": "^4.19.2",
    "typescript": "5.9.2"
  }
