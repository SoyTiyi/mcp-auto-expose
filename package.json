{
  "name": "mcp-auto-expose",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "smoke:fase1": "pnpm --filter @mcp-auto-expose/fastify exec node --import tsx scripts/smoke-fase1.ts"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
